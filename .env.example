# AWS Configuration (Bedrock only — no other AWS services required)
AWS_REGION=us-west-2

# AWS Credentials (omit if using instance profile / IAM role)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Bedrock Model (default Claude Sonnet 4.6)
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# Storage mode: "git" (commit tools to a git repo) or "filesystem" (tools live on disk only)
STORAGE_MODE=git

# Git Repository — only required when STORAGE_MODE=git
GIT_REPO_URL=git@github.com:your-org/cosi.git
GIT_BRANCH=main

# Builder
POLL_INTERVAL=5000

# GovCloud (set to true to use GovCloud endpoints)
AWS_GOVCLOUD=false

# Redis / Session
REDIS_URL=redis://cosi-redis:6379
# Session TTL in seconds (default: 24h)
SESSION_TTL_SECONDS=86400
# Compact session when uncompacted message count exceeds this threshold
SESSION_COMPACTION_THRESHOLD=20

# Tool secrets are stored in secrets.env (gitignored)
# Add entries like: COSI_SECRET_MY_API_KEY=value
# You can manage them via the Cosi UI or edit the file directly.
