# AWS Configuration
AWS_REGION=us-west-2
AWS_SECRET_PREFIX=cosi/

# Bedrock Model (default Claude Sonnet)
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0

# Git Repository
GIT_REPO_URL=https://github.com/your-org/cosi-tools.git
GIT_BRANCH=main

# Builder
POLL_INTERVAL=5000

# GovCloud (set to true to use GovCloud endpoints)
AWS_GOVCLOUD=false

# Redis / Session
REDIS_URL=redis://cosi-redis:6379
# Session TTL in seconds (default: 24h)
SESSION_TTL_SECONDS=86400
# Compact session when uncompacted message count exceeds this threshold
SESSION_COMPACTION_THRESHOLD=20
