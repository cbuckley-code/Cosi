# AWS Configuration
AWS_REGION=us-west-2
AWS_SECRET_PREFIX=cosi/

# Bedrock Model (default Claude Sonnet)
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0

# Git Repository
GIT_REPO_URL=https://github.com/your-org/cosi-tools.git
GIT_BRANCH=main

# Builder
POLL_INTERVAL=5000

# GovCloud (set to true to use GovCloud endpoints)
AWS_GOVCLOUD=false
