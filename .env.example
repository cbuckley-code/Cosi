# ── Air-gapped / restricted-network deployment ────────────────────────────────
# BASE_REGISTRY  : prefix for Docker base images (node, nginx, redis).
#                  Must end with '/'.  Example: my.registry.local/mirror/
# IMAGE_REGISTRY : prefix for built Cosi images (cosi-ui, cosi-orchestrator …).
#                  Must end with '/'.  Example: my.registry.local/cosi/
# IMAGE_TAG      : tag applied to all built Cosi images (default: latest).
# NPM_CONFIG_REGISTRY : npm registry URL.
#                  Example: https://my.nexus.local/repository/npm-proxy/
#
# Typical air-gap build (run once on an internet-connected machine, then transfer):
#   BASE_REGISTRY=my.registry.local/mirror/ \
#   IMAGE_REGISTRY=my.registry.local/cosi/ \
#   NPM_CONFIG_REGISTRY=https://my.nexus.local/repository/npm-proxy/ \
#   ./scripts/airgap-bundle.sh cosi-bundle.tar
#
# Then on the air-gapped host:
#   IMAGE_REGISTRY=my.registry.local/cosi/ ./scripts/airgap-load.sh cosi-bundle.tar
#   IMAGE_REGISTRY=my.registry.local/cosi/ docker compose up -d
#
#BASE_REGISTRY=
#IMAGE_REGISTRY=
#IMAGE_TAG=latest
#NPM_CONFIG_REGISTRY=

# ── AWS Configuration
AWS_REGION=us-west-2
AWS_SECRET_PREFIX=cosi/

# Bedrock Model (default Claude Sonnet)
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0

# Git Repository
GIT_REPO_URL=https://github.com/your-org/cosi-tools.git
GIT_BRANCH=main

# Builder
POLL_INTERVAL=5000

# GovCloud (set to true to use GovCloud endpoints)
AWS_GOVCLOUD=false

# Redis / Session
REDIS_URL=redis://cosi-redis:6379
# Session TTL in seconds (default: 24h)
SESSION_TTL_SECONDS=86400
# Compact session when uncompacted message count exceeds this threshold
SESSION_COMPACTION_THRESHOLD=20
