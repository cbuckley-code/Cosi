# ARG REGISTRY lets you redirect base images to an internal mirror:
#   docker build --build-arg REGISTRY=my.registry.local/ .
ARG REGISTRY=""

# Stage 1: Build React app
FROM ${REGISTRY}node:20-alpine AS builder
ARG NPM_CONFIG_REGISTRY
WORKDIR /app
COPY package.json ./
RUN npm install
COPY . .
RUN npm run build

# Stage 2: nginx with built assets and TLS
FROM ${REGISTRY}nginx:alpine

# Copy built React app
COPY --from=builder /app/dist /usr/share/nginx/html

# Copy nginx config
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Copy TLS certs (generated by generate-cert.sh before build)
COPY certs/cosi.crt /etc/nginx/certs/cosi.crt
COPY certs/cosi.key /etc/nginx/certs/cosi.key

EXPOSE 443
CMD ["nginx", "-g", "daemon off;"]
